# Copy this file to ".env" and fill in real values.  NEVER commit the real .env.

# --- Database (local Postgres) ---
DATABASE_URL=postgresql://coach_user:coach_pass@localhost:5432/ai_financial_coach

# --- JWT auth ---
# Generate a long random string, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- OpenRouter (AI engine) ---
# Leave OPENROUTER_API_KEY blank to run in offline/local mode (deterministic budgets).
# Paste your real key here to get live AI responses.
OPENROUTER_API_KEY=
# Free, high-capacity general model. Alternatives: openrouter/free (auto-picks a
# free model). Free slugs change often — verify at https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Keep False for best free-model compatibility. Set True only if your chosen
# model supports strict JSON (response_format).
OPENROUTER_JSON_MODE=False

# --- CORS: comma-separated frontend origins allowed to call this API ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
